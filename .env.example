# StreamFlix Environment Variables
# Copy this file to .env and fill in values

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/mediahub

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT Secret (change this in production!) ────────────────────
JWT_SECRET=streamflix-secret-key-change-in-production

# ─── ML Service URL ─────────────────────────────────────────────
RECOMMENDER_URL=http://localhost:8000

# ─── Frontend API URL (where your API server is hosted) ─────────
VITE_API_URL=http://localhost:5001

# ─── Postgres (for docker-compose) ──────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=mediahub
